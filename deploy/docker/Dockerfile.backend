FROM node:22-slim

WORKDIR /app

# Force public registry inside container
RUN echo "registry=https://registry.npmjs.org/" > /root/.npmrc

# Copy package files
COPY backend/package*.json ./backend/
RUN cd backend && npm install --omit=dev

# Copy application code
COPY backend/ ./backend/
COPY config.yaml ./

# Content directory (wiki, catalog)
COPY backend/content/ ./backend/content/

WORKDIR /app/backend

EXPOSE 3000

CMD ["node", "index.js"]
