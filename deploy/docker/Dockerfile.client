FROM node:22-slim

WORKDIR /app

# Force public registry inside container
RUN echo "registry=https://registry.npmjs.org/" > /root/.npmrc

# Copy package files
COPY client/package*.json ./

RUN npm install --legacy-peer-deps

# Copy application code
COPY client/ ./

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
